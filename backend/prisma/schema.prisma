// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Property {
  id          Int      @id @default(autoincrement())
  ref         String   @unique
  title       String
  description String?
  price       Float
  area        Float
  frontage    Float?
  depth       Float?
  sector      String?
  block       String?
  lot         String?
  address     String
  district    String
  province    String
  department  String
  latitude    Float?
  longitude   Float?
  status      PropertyStatus @default(AVAILABLE)
  type        PropertyType   @default(URBAN_LOT)
  features    String[]
  images      Image[]
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("properties")
}

model Image {
  id         Int      @id @default(autoincrement())
  url        String
  publicId   String?
  alt        String?
  order      Int      @default(0)
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("images")
}

model Lead {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  email      String?
  message    String?
  source     String   @default("website")
  propertyId Int?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@map("leads")
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum PropertyType {
  URBAN_LOT
  RURAL_LOT
  HOUSE
  APARTMENT
  COMMERCIAL
}
